FROM node:24-alpine

WORKDIR /app

RUN corepack enable
RUN corepack prepare pnpm@9 --activate

COPY college-front/package.json college-front/pnpm-lock.yaml ./

RUN pnpm install

COPY college-front/ .

ARG NEXT_PUBLIC_API_URL=http://localhost:8080
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Internal URL used by the Next.js server-side proxy (baked into routes manifest at build time)
ARG API_URL=http://app:8080
ENV API_URL=${API_URL}

RUN pnpm build

EXPOSE 3000

CMD ["pnpm", "start"]
