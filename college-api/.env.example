# Database
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=

# Resend (email) — get your API key at resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Local document storage — mounted as a Docker volume
DOCUMENTS_STORAGE_PATH=/app/documents

# CORS — full origin URL(s) of the frontend, comma-separated (e.g. http://localhost:3001,https://app.example.com)
CORS_ALLOWED_ORIGINS=

# Frontend
FRONTEND_URL=
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Admin bootstrap (initial admin account — never commit real values)
APP_ADMIN_USERNAME=
APP_ADMIN_EMAIL=
APP_ADMIN_PASSWORD=


# Ollama
# When running via Docker Compose, OLLAMA_BASE_URL is overridden to http://ollama:11434 by the compose environment block.
# This value is for local development only (pointing to Ollama running on the host).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=
