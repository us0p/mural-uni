# Publicly accessible URL of the backend API (used by browsers to reach the API)
# Set this to your server's IP/domain, e.g. http://203.0.113.10:8080 or https://api.muraluni.com.br
NEXT_PUBLIC_API_URL=http://localhost:8080

# Database credentials (must match college-api/.env)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
